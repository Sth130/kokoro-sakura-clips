{
  "installCommand": "bun install",
  "buildCommand": "cd packages/web && bunx vite build",
  "outputDirectory": "packages/web/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!assets|kokoro-images|favicon|og-).*)", "destination": "/index.html" }
  ]
}
